local function ShakeFrame(frame)
    local orig    = frame.Position
    local offsets = { 5, -8, 6, -5, 4, -3, 2, -1, 0 }
    for _, ox in ipairs(offsets) do
        TweenTo(frame, { Position = orig + UDim2.new(0, ox, 0, 0) }, 0.04):Play()
        task.wait(0.045)
    end
    frame.Position = orig
end

local function ValidateKey()
    KStatus.Text       = "checking..."
    KStatus.TextColor3 = Color3.fromRGB(160, 160, 160)
    local entered = KBox.Text:gsub("%s+", "")
    local ok, result = pcall(function()
        return game:HttpGet("https://raw.githubusercontent.com/coldfundss/lala.wtf/refs/heads/main/key")
    end)
    local validKey = ok and result:gsub("%s+", "") or "lalawtf"

    if entered == validKey then
        KStatus.Text       = "valid - loading..."
        KStatus.TextColor3 = Color3.fromRGB(55, 215, 95)
        TweenTo(KBtn, { BackgroundColor3 = Color3.fromRGB(40, 180, 80) }, 0.2):Play()
        task.wait(0.8)
        TweenTo(KCard, { Position = UDim2.new(0.5, 0, 0.4, 0) }, 0.35, Enum.EasingStyle.Back, Enum.EasingDirection.In):Play()
        TweenTo(KBG,   { BackgroundTransparency = 1 }, 0.3):Play()
        task.wait(0.4)
        KeyGui:Destroy()
        _G._lalaKeyTopBar = nil
        _G._lalaKeyBtn    = nil
        _G._lalaKeyTitle  = nil
        MenuOpen     = true
        Main.Visible = true
        _origSetOpen(Library, true)
        SetBlur(true)
    else
        KStatus.Text       = "invalid key"
        KStatus.TextColor3 = Color3.fromRGB(215, 55, 55)
        TweenTo(KBtn, { BackgroundColor3 = Color3.fromRGB(180, 40, 40) }, 0.1):Play()
        task.delay(0.4, function() TweenTo(KBtn, { BackgroundColor3 = CurrentAccent }, 0.2):Play() end)
        task.spawn(function() ShakeFrame(KBoxFrame) end)
    end
end


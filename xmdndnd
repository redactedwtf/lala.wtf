    wrap.BackgroundColor3 = Color3.fromRGB(7, 7, 7)
    wrap.BorderSizePixel  = 0
    wrap.ZIndex           = 3000
    Instance.new("UICorner", wrap).CornerRadius = UDim.new(0, 3)

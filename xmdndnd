local function MakeFlake()
    local vp = GetVP()
    local sz = math.random(1, 6)
    local f  = Instance.new("Frame", SnowCanvas)
    f.Size                   = UDim2.new(0, sz, 0, sz)
    f.Position               = UDim2.new(0, math.random(-50, vp.X + 50), 0, math.random(-vp.Y, vp.Y))
    f.BackgroundColor3       = Color3.fromRGB(255, 255, 255)
    f.BackgroundTransparency = math.random(1, 8) / 10
    f.BorderSizePixel        = 0
    f.ZIndex                 = 2
    if sz >= 4 then
        local glow = Instance.new("ImageLabel", f)
        glow.Size                   = UDim2.new(1, 6, 1, 6)
        glow.Position               = UDim2.new(0, -3, 0, -3)
        glow.BackgroundTransparency = 1
        glow.Image                  = "rbxassetid://6815778798"
        glow.ImageColor3            = Color3.fromRGB(200, 220, 255)
        glow.ImageTransparency      = 0.7
        glow.ZIndex                 = 1
    end
    Instance.new("UICorner", f).CornerRadius = UDim.new(1, 0)
    return {
        inst      = f,
        speed     = math.random(40, 120) / 100,
        drift     = (math.random() - 0.5) * 1.2,
        amp       = math.random(2, 8),
        phase     = math.random() * math.pi * 2,
        windTimer = math.random() * 5,
        opacity   = math.random(3, 10) / 10,
        size      = sz,
    }
end

for i = 1, FLAKE_COUNT do
    table.insert(flakes, MakeFlake())
end

local windStrength = 0
local windTarget   = 0

RunService.RenderStepped:Connect(function(dt)
    if not BlurGui.Enabled or not snowEnabled then return end
    local vp = GetVP()
    local t  = tick()
    if math.random() < 0.01 then windTarget = (math.random() - 0.5) * 3 end
    windStrength = windStrength + (windTarget - windStrength) * dt * 0.5
    for _, sf in ipairs(flakes) do
        local pos = sf.inst.Position
        sf.windTimer = sf.windTimer + dt
        local turbulence = math.sin(sf.windTimer * 2.7) * 0.3
        local wind = (windStrength + sf.drift + turbulence) * dt * 60
        local ax = pos.X.Offset + wind * 0.8
        local ay = pos.Y.Offset + sf.speed * 60 * dt
        ax = ax + math.sin(t * 0.8 + sf.phase) * sf.amp * dt * 0.5
        if ay > vp.Y + 20 then
            ay = -math.random(20, 60)
            ax = math.random(-50, vp.X + 50)
            sf.opacity = math.random(3, 10) / 10
            sf.inst.BackgroundTransparency = 1 - sf.opacity
        end
        if ax > vp.X + 60 then ax = -40 end
        if ax < -60 then ax = vp.X + 40 end
        local fadeStart = vp.Y * 0.7
        if ay > fadeStart then
            local fp = (ay - fadeStart) / (vp.Y * 0.3)
            sf.inst.BackgroundTransparency = math.clamp(1 - sf.opacity * (1 - fp), 0, 1)
        elseif ay < 0 then
            sf.inst.BackgroundTransparency = math.clamp(1 - sf.opacity * (1 - math.abs(ay) / 40), 0, 1)
        else
            sf.inst.BackgroundTransparency = 1 - sf.opacity
        end
        sf.inst.Position = UDim2.new(0, ax, 0, ay)
        if sf.size >= 3 then
            sf.inst.Rotation = math.sin(t * 1.5 + sf.phase) * 15
        end
    end
end)

local function TweenTo(obj, props, t, style, dir)
    style = style or Enum.EasingStyle.Quad
    dir   = dir   or Enum.EasingDirection.Out
    return TS:Create(obj, TweenInfo.new(t or 0.3, style, dir), props)
end

local blurActive = false

local function SetBlur(on)
    blurActive = on
    if on then
        BlurGui.Enabled    = true
        BlurEffect.Enabled = true
        local intensity = Library.Flags and Library.Flags["blur_intensity"] or "Medium"
        local sizes = { None=0, Low=8, Medium=18, High=32, Ultra=52 }
        TweenTo(BlurEffect, { Size = sizes[intensity] or 18 }, 0.35):Play()
        TweenTo(DimOverlay, { BackgroundTransparency = 0.5 }, 0.35):Play()
    else
        TweenTo(BlurEffect, { Size = 0 }, 0.3):Play()
        TweenTo(DimOverlay, { BackgroundTransparency = 1 }, 0.3):Play()
        task.delay(0.35, function()
            if not blurActive then
                BlurEffect.Enabled = false
                BlurGui.Enabled    = false
            end
        end)
    end
end


-- ── Configs ───────────────────────────────────────────────────────────────────

local CFG_FOLDER = "lala-wtf-cfgs"
if not isfolder(CFG_FOLDER) then makefolder(CFG_FOLDER) end
local configList = nil

local function RefreshConfigList()
    local names = {}
    for _, f in ipairs(listfiles(CFG_FOLDER)) do
        local n = f:match("([^/\\]+)%.txt$")
        if n and n ~= "autoload" then table.insert(names, n) end
    end
    if configList then configList:Refresh(names) end
end

local SecConfig = PgSettings:Section({
    Name       = "Configs",
    LeftTitle  = "files",
    RightTitle = "actions",
})

configList = SecConfig:List({
    Name    = "Config List",
    Side    = "Left",
    Flag    = "config_list",
    options = {},
    default = nil,
})

SecConfig:Textbox({
    Name        = "Config Name",
    Side        = "Left",
    Flag        = "config_name",
    placeholder = "enter name...",
    default     = "",
})

SecConfig:Button({
    Name     = "Save Config",
    Side     = "Right",
    callback = function()
        local n = Library.Flags["config_name"]
        if n and n ~= "" then
            writefile(CFG_FOLDER.."/"..n..".txt", Library:GetConfig())
            RefreshConfigList()
            Notify({ Title = "Saved", Message = n, Duration = 3 })
        else
            Notify({ Title = "Error", Message = "Enter a name", Duration = 2 })
        end
    end,
})

SecConfig:Button({
    Name     = "Load Config",
    Side     = "Right",
    callback = function()
        local s = Library.Flags["config_list"]
        if s then
            local ok, d = pcall(readfile, CFG_FOLDER.."/"..s..".txt")
            if ok and d then Library:LoadConfig(d) Notify({ Title = "Loaded", Message = s, Duration = 3 }) end
        else
            Notify({ Title = "Error", Message = "Select a config", Duration = 2 })
        end
    end,
})

SecConfig:Button({
    Name     = "Overwrite Config",
    Side     = "Right",
    callback = function()
        local s = Library.Flags["config_list"]
        if s then writefile(CFG_FOLDER.."/"..s..".txt", Library:GetConfig()) Notify({ Title = "Updated", Message = s, Duration = 3 }) end
    end,
})

SecConfig:Button({
    Name     = "Delete Config",
    Side     = "Right",
    callback = function()
        local s = Library.Flags["config_list"]
        if s then
            pcall(delfile, CFG_FOLDER.."/"..s..".txt")
            RefreshConfigList()
            Notify({ Title = "Deleted", Message = s, Duration = 3 })
        end
    end,
})

SecConfig:Button({
    Name     = "Set Autoload",
    Side     = "Right",
    callback = function()
        local s = Library.Flags["config_list"]
        if s then writefile(CFG_FOLDER.."/autoload.txt", s) Notify({ Title = "Autoload Set", Message = s, Duration = 3 }) end
    end,
})

SecConfig:Button({
    Name     = "Clear Autoload",
    Side     = "Right",
    callback = function()
        pcall(delfile, CFG_FOLDER.."/autoload.txt")
        Notify({ Title = "Cleared", Message = "Autoload removed", Duration = 3 })
    end,
})

SecConfig:Button({
    Name     = "Delete All",
    Side     = "Right",
    callback = function()
        for _, f in ipairs(listfiles(CFG_FOLDER)) do pcall(delfile, f) end
        RefreshConfigList()
        Notify({ Title = "Wiped", Message = "All configs deleted", Duration = 3 })
    end,
})

SecConfig:Button({
    Name     = "Export Config",
    Side     = "Right",
    callback = function()
        setclipboard(Library:GetConfig())
        Notify({ Title = "Copied", Message = "Config in clipboard", Duration = 2 })
    end,
})

SecConfig:Button({
    Name     = "Import Config",
    Side     = "Right",
    callback = function()
        local c = getclipboard()
        if c and c ~= "" then Library:LoadConfig(c) Notify({ Title = "Imported", Message = "Loaded from clipboard", Duration = 3 }) end
    end,
})


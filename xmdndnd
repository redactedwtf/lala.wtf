-- ─────────────────────────────────────────────────────────────────────────────
--  Scroll wrapper helper
--  Call AFTER all elements have been added to a section.
--  Finds the two column frames the library created (Left / Right) and wraps
--  each in a ScrollingFrame so content can overflow without breaking layout.
-- ─────────────────────────────────────────────────────────────────────────────
local function WrapSectionScroll(section)
    task.defer(function()
        -- The library normally creates two children named "Left" and "Right"
        -- inside the section holder. We clip them inside scrollframes.
        local holder = section.Holder or section.Window or section

        local function WrapColumn(col)
            if not col then return end
            -- Measure content height
            local contentH = 0
            for _, ch in ipairs(col:GetChildren()) do
                if ch:IsA("GuiObject") then
                    contentH = contentH + ch.AbsoluteSize.Y + 3
                end
            end
            contentH = math.max(contentH, col.AbsoluteSize.Y)

            -- Create scroll wrapper matching the column's position/size
            local sf = Instance.new("ScrollingFrame")
            sf.Size                       = col.Size
            sf.Position                   = col.Position
            sf.BackgroundTransparency     = 1
            sf.BorderSizePixel            = 0
            sf.ScrollBarThickness         = 3
            sf.ScrollBarImageColor3       = CurrentAccent
            sf.ScrollBarImageTransparency = 0.4
            sf.CanvasSize                 = UDim2.new(0, 0, 0, contentH + 10)
            sf.ClipsDescendants           = true
            sf.ZIndex                     = col.ZIndex
            sf.Parent                     = col.Parent

            -- Move all children of col into sf
            for _, ch in ipairs(col:GetChildren()) do
                ch.Parent = sf
            end

            -- Hide original column shell
            col.BackgroundTransparency = 1
            col.Visible = false

            -- Auto-expand canvas when new children are added
            sf.ChildAdded:Connect(function()
                local h = 0
                for _, ch in ipairs(sf:GetChildren()) do
                    if ch:IsA("GuiObject") and not ch:IsA("UIListLayout") and not ch:IsA("UIPadding") then
                        h = h + ch.AbsoluteSize.Y + 3
                    end
                end
                sf.CanvasSize = UDim2.new(0, 0, 0, h + 10)
            end)
        end

        WrapColumn(holder:FindFirstChild("Left"))
        WrapColumn(holder:FindFirstChild("Right"))
    end)
end


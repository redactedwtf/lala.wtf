local function MakePill(parent, yPos, label)
    local wrap = Instance.new("Frame", parent)
    wrap.Size             = UDim2.new(0, 64, 0, 22)
    wrap.Position         = UDim2.new(0, 4, 0, yPos)
    wrap.BackgroundColor3 = Color3.fromRGB(7, 7, 7)

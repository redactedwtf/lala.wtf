task.delay(0.6, function()
    local function fire()
        task.delay(0.3, function()
            Notify({
                Title    = "lala.wtf",
                Message  = "loaded on "..(IsMobile and "mobile" or IsGamepad and "gamepad" or "pc"),
                Duration = 4,
            })
        end)
    end
    if not Main.Visible then
        local conn
        conn = Main:GetPropertyChangedSignal("Visible"):Connect(function()
            if Main.Visible then conn:Disconnect() fire() end
        end)
    else
        fire()
    end
end)

local function ApplyAccent(col, animated)
    CurrentAccent = col
    Library:ChangeAccent(col)
    local dur = animated and 0.2 or 0
    for _, b in ipairs(accentBars)   do TweenTo(b, { BackgroundColor3 = col }, dur):Play() end
    for _, l in ipairs(accentLabels) do TweenTo(l, { TextColor3       = col }, dur):Play() end
    pcall(function() TweenTo(_G._lalaKeyTopBar, { BackgroundColor3 = col }, dur):Play() end)
    pcall(function() TweenTo(_G._lalaKeyBtn,    { BackgroundColor3 = col }, dur):Play() end)
    pcall(function() TweenTo(_G._lalaKeyTitle,  { TextColor3       = col }, dur):Play() end)
end


    wrap.ZIndex           = 999
    Instance.new("UICorner", wrap).CornerRadius = UDim.new(0, 3)
    Instance.new("UIStroke", wrap).Color = Color3.fromRGB(22, 22, 22)

    local inner = Instance.new("Frame", wrap)
    inner.Size             = UDim2.new(1, -2, 1, -2)
    inner.Position         = UDim2.new(0, 1, 0, 1)
    inner.BackgroundColor3 = Color3.fromRGB(10, 10, 10)
    inner.BorderSizePixel  = 0
    inner.ZIndex           = 999
    Instance.new("UICorner", inner).CornerRadius = UDim.new(0, 3)

    local bar = Instance.new("Frame", inner)
    bar.Size             = UDim2.new(1, 0, 0, 1)
    bar.BackgroundColor3 = CurrentAccent
    bar.BorderSizePixel  = 0
    bar.ZIndex           = 1000
    RegisterAccent(bar, "bar")

    local btn = Instance.new("TextButton", inner)
    btn.Size                   = UDim2.new(1, 0, 1, 0)
    btn.BackgroundTransparency = 1
    btn.Text                   = label
    btn.TextColor3             = Color3.fromRGB(65, 65, 65)
    btn.TextSize               = FontSize
    btn.FontFace               = UIFont
    btn.ZIndex                 = 1001
    btn.AutoButtonColor        = false

    btn.MouseEnter:Connect(function()
        TweenTo(btn, { TextColor3 = Color3.fromRGB(205, 205, 205) }, 0.12):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenTo(btn, { TextColor3 = Color3.fromRGB(65, 65, 65) }, 0.12):Play()
    end)
    btn.MouseButton1Down:Connect(function()
        TweenTo(inner, { BackgroundColor3 = Color3.fromRGB(16, 16, 16) }, 0.08):Play()
    end)
    btn.MouseButton1Up:Connect(function()
        TweenTo(inner, { BackgroundColor3 = Color3.fromRGB(10, 10, 10) }, 0.12):Play()
    end)

    return wrap, inner, bar, btn
end

